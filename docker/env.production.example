# =============================================================================
# attune-sb-smart-forms — Production environment (VPS)
# Copy to /opt/attune-sb/.env on the server and fill in every blank.
# Read by docker-compose.prod.yml (interpolation + env_file for the api).
# Generate secrets:  openssl rand -hex 48   (JWT/internal keys)
#                    openssl rand -hex 32   (ENCRYPTION_KEY — must be 64 hex chars)
# =============================================================================

# --- Deployment ---
# The public domain. Change here (+ DNS + certbot) to move subdomains — images
# are domain-agnostic, nothing needs rebuilding.
DOMAIN=sfsb.attuneitus.com
APP_VERSION=0.1.0

# Images pulled by compose (overridden per-release by the deploy pipeline).
API_IMAGE=ghcr.io/masseyconsultants/attune-sb-smart-forms-api:latest
WEB_IMAGE=ghcr.io/masseyconsultants/attune-sb-smart-forms-web:latest

# --- Infrastructure secrets ---
POSTGRES_PASSWORD=
REDIS_PASSWORD=

# --- Application secrets ---
JWT_SECRET=
JWT_REFRESH_SECRET=
ENCRYPTION_KEY=
# BFF trust boundary key (required in production, min 32 chars)
INTERNAL_API_KEY=

# --- Platform admin (first seed only; remove after the account exists) ---
PLATFORM_ADMIN_EMAIL=admin@attuneitus.com
PLATFORM_ADMIN_PASSWORD=

# --- Stripe (live mode; app runs trial-only with these blank) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SOLO_MONTHLY=
STRIPE_PRICE_SOLO_ANNUAL=
STRIPE_PRICE_GROWTH_MONTHLY=
STRIPE_PRICE_GROWTH_ANNUAL=
STRIPE_PRICE_BUSINESS_MONTHLY=
STRIPE_PRICE_BUSINESS_ANNUAL=

# --- Email (Resend) ---
EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM="Attune Smart Forms <noreply@attuneitus.com>"

# --- Observability (optional) ---
SENTRY_DSN=
