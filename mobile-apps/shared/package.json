{
  "name": "@attune-sb/mobile-shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared mobile utilities — auth interceptor, secure token storage, brand constants",
  "author": "Robert Massey",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@attune-sb/shared-types": "workspace:*",
    "axios": "^1.6.0",
    "expo-secure-store": "~15.0.8"
  },
  "devDependencies": {
    "@attune-sb/eslint-config": "workspace:*",
    "@types/jest": "^29.5.0",
    "@types/react": "^19.0.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": "*"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/*.spec.ts"
    ],
    "modulePathIgnorePatterns": [
      "<rootDir>/dist/"
    ]
  }
}
