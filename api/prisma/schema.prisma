// Author: Robert Massey | Created: 2026-07-12 | Module: Prisma Schema v1 (Sprint 0)
// Conventions: UUID v4 PKs, createdAt/updatedAt/deletedAt on domain tables,
// snake_case column mapping, every FK and WHERE column indexed.
// Entitlement models follow docs/PRICING_AND_ENTITLEMENTS.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Enums ---

enum Role {
  PLATFORM_ADMIN
  OWNER
  ADMIN
  BUILDER
  VIEWER
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  PAUSED
}

enum OrgLifecycleState {
  ACTIVE
  EXPIRED_TRIAL
  CANCELED
  PURGE_PENDING
  PURGED
}

enum Meter {
  SUBMISSIONS
  DOC_FILLS
  WORKFLOW_RUNS
  EMAILS
  AI_CREDITS
  STORAGE_BYTES
}

enum PurgePhase {
  BLOBS_DELETED
  HARD_DELETED
  RESTORED
  LEGAL_HOLD_SKIP
}

enum FormStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  APPROVED
  REJECTED
  // Accepted over the plan cap: stored + quarantined, never dropped.
  OVER_LIMIT
}

enum DocumentTemplateStatus {
  UPLOADED
  PROCESSING
  READY
  FAILED
}

enum WorkflowStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum WorkflowRunStatus {
  PENDING
  RUNNING
  // Waiting on a human (approval node). currentNodeId marks where.
  PAUSED
  COMPLETED
  FAILED
  // Recorded when WORKFLOW_RUNS is at cap — visible in the runs list, never
  // silently dropped. The trigger submission is untouched.
  SKIPPED_LIMIT
  CANCELED
}

enum WorkflowRunStepStatus {
  COMPLETED
  FAILED
  SKIPPED
}

enum LibraryTemplateScope {
  // Curated gallery — browsable without auth (SEO/acquisition surface).
  PUBLIC
  // Customer-published for their own org (publishOrgTemplates feature).
  ORG
}

// --- Tenancy ---

model Organization {
  id             String            @id @default(uuid())
  name           String
  slug           String            @unique
  settings       Json              @default("{}")
  isActive       Boolean           @default(true) @map("is_active")

  // Data lifecycle (docs/PRICING_AND_ENTITLEMENTS.md § Data Lifecycle & Purge)
  lifecycleState   OrgLifecycleState @default(ACTIVE) @map("lifecycle_state")
  readOnlyAt       DateTime?         @map("read_only_at")
  purgeScheduledAt DateTime?         @map("purge_scheduled_at")
  purgeRequestedAt DateTime?         @map("purge_requested_at")
  legalHoldAt      DateTime?         @map("legal_hold_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  users                User[]
  subscription         Subscription?
  usageCounters        UsageCounter[]
  usageEvents          UsageEvent[]
  entitlementOverrides EntitlementOverride[]
  inviteTokens         InviteToken[]
  forms                Form[]
  submissions          Submission[]
  documentTemplates    DocumentTemplate[]
  workflows            Workflow[]
  workflowRuns         WorkflowRun[]
  libraryTemplates     LibraryTemplate[]
  notifications        Notification[]

  @@index([lifecycleState])
  @@index([deletedAt])
  @@map("organizations")
}

// --- Users & Auth ---

model User {
  id           String  @id @default(uuid())
  email        String  @unique
  passwordHash String? @map("password_hash")
  firstName    String  @map("first_name")
  lastName     String  @map("last_name")
  role         Role    @default(VIEWER)
  isActive     Boolean @default(true) @map("is_active")

  emailVerified      Boolean   @default(false) @map("email_verified")
  mustChangePassword Boolean   @default(false) @map("must_change_password")
  acceptedTermsAt    DateTime? @map("accepted_terms_at")

  // Lockout (5 fails / 15 min)
  failedAttempts Int       @default(0) @map("failed_attempts")
  lockedUntil    DateTime? @map("locked_until")

  firstLoginAt DateTime? @map("first_login_at")
  lastLoginAt  DateTime? @map("last_login_at")
  loginCount   Int       @default(0) @map("login_count")

  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]

  @@index([organizationId])
  @@index([deletedAt])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @map("token_hash")
  // Family tracking: reuse of a revoked token revokes the whole family.
  family    String
  isRevoked Boolean  @default(false) @map("is_revoked")
  expiresAt DateTime @map("expires_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([family])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  jtiHash   String    @unique @map("jti_hash")
  usedAt    DateTime? @map("used_at")
  expiresAt DateTime  @map("expires_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("password_reset_tokens")
}

model InviteToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique @map("token_hash")
  email     String
  firstName String    @map("first_name")
  lastName  String    @map("last_name")
  role      Role
  expiresAt DateTime  @map("expires_at")
  acceptedAt DateTime? @map("accepted_at")

  orgId       String       @map("org_id")
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  invitedById String       @map("invited_by_id")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([orgId])
  @@index([email])
  @@map("invite_tokens")
}

// --- Billing & Entitlements (Stripe is billing input; this is the authority) ---

// Seeded rows mirror PLAN_ENTITLEMENTS for reporting joins and Stripe price
// mapping. Limits are NOT stored here at runtime — code constants are authority.
model Plan {
  id                   String @id // 'solo' | 'growth' | 'business'
  displayName          String @map("display_name")
  stripePriceIdMonthly String @default("") @map("stripe_price_id_monthly")
  stripePriceIdAnnual  String @default("") @map("stripe_price_id_annual")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("plans")
}

model Subscription {
  id                   String             @id @default(uuid())
  organizationId       String             @unique @map("organization_id")
  organization         Organization       @relation(fields: [organizationId], references: [id])
  planId               String             @map("plan_id") // PlanId incl. 'trial'
  status               SubscriptionStatus
  stripeCustomerId     String?            @map("stripe_customer_id")
  stripeSubscriptionId String?            @map("stripe_subscription_id")
  trialEndsAt          DateTime?          @map("trial_ends_at")
  currentPeriodEnd     DateTime?          @map("current_period_end")
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")
  // Usage counters reset on this day of month (org's billing anchor)
  billingAnchorDay     Int                @map("billing_anchor_day")
  seats                Int                @default(1)
  // First failed-invoice timestamp — drives the dunning grace windows
  pastDueSince         DateTime?          @map("past_due_since")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([trialEndsAt])
  @@index([stripeCustomerId])
  @@map("subscriptions")
}

// One row per org × meter × period. Atomic increments; Redis cache in front.
model UsageCounter {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])
  meter          Meter
  periodStart    DateTime     @map("period_start")
  periodEnd      DateTime     @map("period_end")
  used           BigInt       @default(0)
  // Once-per-period soft-limit notification latch
  softWarnedAt   DateTime?    @map("soft_warned_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([organizationId, meter, periodStart])
  @@index([organizationId])
  @@map("usage_counters")
}

// Append-only, idempotent ledger — source for billing reconciliation & analytics.
model UsageEvent {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])
  meter          Meter
  quantity       BigInt
  idempotencyKey String       @unique @map("idempotency_key")
  refType        String?      @map("ref_type") // 'submission' | 'workflowExecution' | ...
  refId          String?      @map("ref_id")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([organizationId, meter])
  @@map("usage_events")
}

// Sales exceptions, grandfathering, temporary grants.
model EntitlementOverride {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])
  entitlement    String
  value          Json
  expiresAt      DateTime?    @map("expires_at")
  reason         String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@map("entitlement_overrides")
}

// Stripe webhook event dedupe — handlers are idempotent by event ID.
// --- Forms (Sprint 3) ---

model Form {
  id          String     @id @default(uuid())
  name        String
  description String?
  // Public fill-page identifier for /f/[slug] (S4) — unique, regenerable.
  slug        String     @unique
  // form-engine FormSchema contract: { fields, settings, navigationRules }
  schema      Json       @default("{\"fields\":[]}")
  status      FormStatus @default(DRAFT)
  version     Int        @default(1)

  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdById    String       @map("created_by_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  versions         FormVersion[]
  submissions      Submission[]
  documentTemplate DocumentTemplate?

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([deletedAt])
  @@map("forms")
}

// SmartMapper: a customer's own PDF/DOCX form, mapped so submissions can fill
// it. Org-scoped and counted against the plan's uploadedTemplates cap. One
// template links to at most one form at v1 (mappings reference field ids).
model DocumentTemplate {
  id     String                 @id @default(uuid())
  name   String
  status DocumentTemplateStatus @default(UPLOADED)
  // Populated when processing fails so the UI can explain, not just say FAILED.
  failureReason String? @map("failure_reason")

  // Blob keys: original upload + the PDF actually rendered/filled
  // (identical for PDF uploads; converted copy for DOCX).
  originalKey String @map("original_key")
  pdfKey      String @map("pdf_key")
  mimeType    String @map("mime_type")
  sizeBytes   Int    @map("size_bytes")

  pageCount Int @default(0) @map("page_count")
  // JSON array of { width, height } per page, PDF points.
  pageDimensions Json @default("[]") @map("page_dimensions")
  // JSON array of FieldCoordinateMapping (shared-types contract).
  fieldMappings Json @default("[]") @map("field_mappings")

  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])
  formId         String?      @unique @map("form_id")
  form           Form?        @relation(fields: [formId], references: [id])
  createdById    String       @map("created_by_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([organizationId])
  @@index([deletedAt])
  @@map("document_templates")
}

// Public intake rows. OVER_LIMIT rows are quarantined (hidden from data views
// and exports) until the plan has headroom again — data is never dropped.
model Submission {
  id          String           @id @default(uuid())
  formId      String           @map("form_id")
  form        Form             @relation(fields: [formId], references: [id])
  formVersion Int              @map("form_version")
  data        Json
  status      SubmissionStatus @default(SUBMITTED)
  submittedAt DateTime?        @map("submitted_at")

  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])

  // Abuse forensics for public intake (no auth to attribute)
  sourceIp String? @map("source_ip")

  // SmartMapper document fill (S6): blob key + size of the generated PDF.
  // Null = no template mapped, fill failed, or DOC_FILLS cap reached — the
  // submission itself is always kept.
  filledDocumentKey   String?   @map("filled_document_key")
  filledDocumentBytes Int?      @map("filled_document_bytes")
  filledAt            DateTime? @map("filled_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([formId, status])
  @@index([organizationId, status])
  @@index([deletedAt])
  @@map("submissions")
}

// Immutable snapshot created on every publish/republish. The public fill page
// and submissions always reference a version, never the mutable draft schema.
model FormVersion {
  id          String   @id @default(uuid())
  formId      String   @map("form_id")
  form        Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  version     Int
  schema      Json
  changelog   String?
  publishedBy String?  @map("published_by")
  publishedAt DateTime @default(now()) @map("published_at")

  @@unique([formId, version])
  @@index([formId])
  @@map("form_versions")
}

// --- Workflows (Sprint 7) ---

// Visual node-graph automation. The mutable draft graph lives on the row;
// every publish snapshots an immutable WorkflowVersion that runs pin to.
model Workflow {
  id          String         @id @default(uuid())
  name        String
  description String?
  // Graph: WorkflowNode[] / WorkflowEdge[] (shared-types contracts)
  nodes       Json           @default("[]")
  edges       Json           @default("[]")
  status      WorkflowStatus @default(DRAFT)
  version     Int            @default(1)
  color       String         @default("#F97316")

  // The form whose accepted public submissions trigger this workflow.
  // Authoritative for trigger lookup; the graph's form node mirrors it.
  triggerFormId String? @map("trigger_form_id")

  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdById    String       @map("created_by_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  versions WorkflowVersion[]
  runs     WorkflowRun[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([triggerFormId])
  @@index([deletedAt])
  @@map("workflows")
}

// Immutable snapshot per publish. Runs execute against a version, never the
// mutable draft — mirrors FormVersion.
model WorkflowVersion {
  id          String   @id @default(uuid())
  workflowId  String   @map("workflow_id")
  workflow    Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  version     Int
  nodes       Json
  edges       Json
  publishedBy String?  @map("published_by")
  publishedAt DateTime @default(now()) @map("published_at")

  @@unique([workflowId, version])
  @@index([workflowId])
  @@map("workflow_versions")
}

// One execution of a workflow version. State is the shared blackboard adapters
// read/write; each node execution appends a WorkflowRunStep ledger row.
model WorkflowRun {
  id              String            @id @default(uuid())
  workflowId      String            @map("workflow_id")
  workflow        Workflow          @relation(fields: [workflowId], references: [id])
  workflowVersion Int               @map("workflow_version")
  status          WorkflowRunStatus @default(PENDING)
  currentNodeId   String?           @map("current_node_id")
  state           Json              @default("{}")
  // 'submission' at v1; 'manual' | 'schedule' later
  triggerType     String            @default("submission") @map("trigger_type")
  // Trigger submission — reference only (no FK) so runs survive submission
  // soft-deletes and purge ordering stays simple.
  submissionId    String?           @map("submission_id")
  error           String?

  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])

  // Blob bytes written by this run (pdf_generate / fill_document outputs).
  // Aggregated into the STORAGE_BYTES live sum; run deletion reclaims space.
  artifactBytes Int @default(0) @map("artifact_bytes")

  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  steps          WorkflowRunStep[]
  approvalTokens ApprovalToken[]

  @@index([workflowId, status])
  @@index([organizationId, status])
  @@index([submissionId])
  @@map("workflow_runs")
}

// Public no-login approval links (Growth tier). The raw token is emailed and
// never stored — only its SHA-256. One decision per token; expiry enforced.
model ApprovalToken {
  id        String      @id @default(uuid())
  tokenHash String      @unique @map("token_hash")
  runId     String      @map("run_id")
  run       WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  nodeId    String      @map("node_id")

  organizationId String @map("organization_id")
  // Approver email the link was sent to (display only — the token IS the auth)
  assignedTo String  @map("assigned_to")
  message    String?

  decision  String? // 'approved' | 'rejected'
  note      String?
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([runId])
  @@index([organizationId])
  @@map("approval_tokens")
}

// Per-node execution ledger: status, output, error, timing. Input is the run
// state at step start — not duplicated per row to keep the table lean.
model WorkflowRunStep {
  id       String                @id @default(uuid())
  runId    String                @map("run_id")
  run      WorkflowRun           @relation(fields: [runId], references: [id], onDelete: Cascade)
  nodeId   String                @map("node_id")
  nodeType String                @map("node_type")
  status   WorkflowRunStepStatus
  output   Json?
  error    String?
  durationMs Int? @map("duration_ms")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([runId])
  @@map("workflow_run_steps")
}

model StripeWebhookEvent {
  id          String   @id // Stripe event id (evt_...)
  type        String
  processedAt DateTime @default(now()) @map("processed_at")

  @@map("stripe_webhook_events")
}

// --- Data lifecycle audit ---

model PurgeAuditLog {
  id             String     @id @default(uuid())
  // Survives as reference to tombstone — intentionally NOT a FK so hard-deleted
  // orgs keep their audit trail.
  organizationId String     @map("organization_id")
  phase          PurgePhase
  entityCounts   Json       @map("entity_counts") // { forms: n, submissions: n, blobsBytes: n, ... }
  triggeredBy    String     @map("triggered_by") // 'lifecycle-sweep' | 'user-request' | 'support:[userId]'

  createdAt DateTime @default(now()) @map("created_at")

  @@index([organizationId])
  @@map("purge_audit_logs")
}

// Minimal record that survives a purge: no form/submission/document content.
model OrgTombstone {
  id             String   @id @default(uuid())
  organizationId String   @unique @map("organization_id")
  orgName        String   @map("org_name")
  ownerEmailHash String   @map("owner_email_hash") // SHA-256
  planAtExit     String   @map("plan_at_exit")
  lifecyclePath  String   @map("lifecycle_path") // 'trial' | 'canceled'
  entityCounts   Json     @map("entity_counts")
  purgedAt       DateTime @map("purged_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("org_tombstones")
}

// --- Template library (S9) ---

// A template bundles a form schema with an optional workflow graph. Cloning
// materializes both as DRAFTs in the caller's org. PUBLIC rows are curated
// (organizationId null); ORG rows are customer-published and only visible to
// their org. Category is validated in code against LIBRARY_CATEGORIES.
model LibraryTemplate {
  id          String               @id @default(uuid())
  slug        String               @unique
  name        String
  description String
  category    String
  scope       LibraryTemplateScope @default(PUBLIC)
  // form-engine FormSchema contract
  schema      Json
  // { name, nodes, edges } | null — cloned as a DRAFT workflow when present
  workflow    Json?
  // Times cloned into an org — gallery social proof + curation signal.
  installCount Int @default(0) @map("install_count")

  // Null for curated PUBLIC templates.
  organizationId String?       @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id])
  createdById    String?       @map("created_by_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([scope, category])
  @@index([organizationId])
  @@index([deletedAt])
  @@map("library_templates")
}

// --- In-app notifications (S9) ---

// Org-scoped feed with optional user targeting (userId null = visible to all
// org members). Emitters: usage soft-warnings, approval decisions, workflow
// failures, trial reminders. Email delivery is separate (EmailService).
model Notification {
  id    String  @id @default(uuid())
  type  String // 'usage_warning' | 'approval_decided' | 'workflow_failed' | 'trial_reminder' | ...
  title String
  body  String
  link  String?

  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String?      @map("user_id")

  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([organizationId, createdAt])
  @@index([organizationId, readAt])
  @@map("notifications")
}

// Trial-abuse fingerprint — purged trial orgs cannot re-trial for free.
model TrialFingerprint {
  id              String   @id @default(uuid())
  emailDomainHash String   @map("email_domain_hash") // SHA-256 of the signup email domain
  paymentHash     String?  @map("payment_hash") // Stripe payment-method fingerprint hash
  organizationId  String   @map("organization_id") // reference only, no FK

  createdAt DateTime @default(now()) @map("created_at")

  @@index([emailDomainHash])
  @@map("trial_fingerprints")
}
