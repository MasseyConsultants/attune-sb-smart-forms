{
  "name": "attune-sb-api",
  "version": "0.1.0",
  "private": true,
  "description": "attune-sb-smart-forms NestJS REST API",
  "author": "Robert Massey",
  "scripts": {
    "dev": "nest start --watch",
    "build": "pnpm exec nest build",
    "start": "node dist/main",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch --runInBand",
    "test:coverage": "jest --runInBand --forceExit --coverage",
    "clean": "rimraf dist coverage",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "seed": "ts-node --transpile-only --project tsconfig.seed.json prisma/seed.ts"
  },
  "dependencies": {
    "@attune-sb/form-engine": "workspace:*",
    "@attune-sb/shared-types": "workspace:*",
    "@nestjs/bullmq": "^10.2.0",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/swagger": "^7.3.0",
    "@nestjs/terminus": "^10.2.0",
    "@nestjs/throttler": "^5.1.0",
    "@prisma/client": "^5.10.0",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.3",
    "bullmq": "^5.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "exceljs": "^4.4.0",
    "fuzzball": "^2.2.6",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.0",
    "joi": "^17.12.0",
    "mammoth": "^1.12.0",
    "nodemailer": "^6.9.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "3.11.174",
    "prisma": "^5.10.0",
    "puppeteer": "^25.3.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "stripe": "^17.0.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@attune-sb/eslint-config": "workspace:*",
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/body-parser": "^1.19.5",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.0",
    "@types/multer": "^2.2.0",
    "@types/node": "^20.11.0",
    "@types/nodemailer": "^6.4.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.0",
    "@types/uuid": "^9.0.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "rimraf": "^5.0.0",
    "supertest": "^6.3.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/*.module.ts",
      "!main.ts",
      "!**/dto/**"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "setupFiles": [
      "<rootDir>/test-setup.ts"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1",
      "^@attune-sb/shared-types$": "<rootDir>/../../packages/shared-types/src"
    }
  },
  "prisma": {
    "seed": "ts-node --transpile-only --project tsconfig.seed.json prisma/seed.ts"
  }
}
